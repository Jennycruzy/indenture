# Sepolia deploy (consumed by scripts/deploy-cloistra-sepolia.sh).
# Copy this file to .env.local and fill in values.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=

# Sepolia Corridor deploy (consumed by packages/foundry/script/DeployCorridor.s.sol).
ENGINE_ADDRESS=
COMPLIANCE_OFFICER_ADDRESS=
# Optional; defaults to deployer.
OPERATOR_ADDRESS=
# Optional; defaults to keccak256("cloistra-sepolia-corridor-v1").
MANDATE_ID=
WINDOW_SECONDS=2592000
