# CLOISTRA off-ramp listener — Phase C2 (SANDBOX ONLY by design; see VERIFICATION.md).
# Copy to .env.local and fill in. .env.local is gitignored — key material is server-side, never committed.

# --- Chain: read corridor clears as the compliance officer ---
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ENGINE_ADDRESS=0xF34694B35841ceA17acc9Fb86D2b5bd3Ac276Eee # deployed CLOISTRA engine; required
CORRIDOR_ADDRESS=0xD77489caCa9C6549CCeD4A500B46019BE2d225c4 # deployed CLOISTRA Corridor; required
FROM_BLOCK=11217667              # fresh CLOISTRA Corridor deploy block

# --- Compliance officer: the ONLY identity granted ACL decrypt over `moved` ---
# NEVER the operator or sender key. Server-side only.
OFFICER_PRIVATE_KEY=

# --- Flutterwave v3 (sandbox): the secret key is the whole "what do I provide" ---
# Test mode is keyed by the FLWSECK_TEST secret itself — same host, no separate sandbox URL.
# Only the SECRET key is needed for payouts (public key = checkout, encryption key = card charging).
FLW_SECRET_KEY=                  # FLWSECK_TEST-…  (a live FLWSECK- key is refused by index.ts)
FLW_BASE_URL=https://api.flutterwave.com/v3
# Sandbox only: appended to the payout reference to drive Flutterwave's mock disburse callback.
#   _PMCKDU_1 → SUCCESSFUL after ~1 min ; _PMCK_ST_FDU_1 → FAILED. Empty = stays PENDING. Prod: leave empty.
FLW_TEST_REFERENCE_SUFFIX=

# --- Beneficiary map: on-chain recipient address -> KYC'd fiat destination (JSON) ---
# Nigeria example (bank transfer). Bank codes come from GET /v3/banks/NG.
# The sandbox test account 0690000032 / bank 044 (Access Bank) simulates a successful transfer.
# BENEFICIARIES_JSON={"0xRecipient...":{"currency":"NGN","type":"bank","network":"044","accountNumber":"0690000032","accountName":"Jane Doe"}}
BENEFICIARIES_JSON={}
